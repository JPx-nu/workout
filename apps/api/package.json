{
	"name": "@triathlon/api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "./src/server.ts",
	"types": "./src/server.ts",
	"scripts": {
		"build:deps": "pnpm --filter @triathlon/types build && pnpm --filter @triathlon/core build",
		"dev": "npx -y kill-port 8787 && node ./scripts/dev-watch.mjs",
		"build": "tsc",
		"build:deploy": "node esbuild.deploy.mjs",
		"prebuild": "pnpm run build:deps",
		"prebuild:deploy": "pnpm run build:deps",
		"predev": "pnpm run build:deps",
		"pretest": "pnpm run build:deps",
		"pretype-check": "pnpm run build:deps",
		"start": "node --env-file-if-exists=.env --env-file-if-exists=.env.local dist/server.js",
		"test": "vitest run",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/langchain": "^2.0.111",
		"@hono/node-server": "1.19.10",
		"@hono/swagger-ui": "0.5.3",
		"@hono/zod-openapi": "1.2.2",
		"@langchain/core": "^1.1.28",
		"@langchain/langgraph": "^1.1.5",
		"@langchain/openai": "^1.2.10",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
		"@opentelemetry/instrumentation": "^0.212.0",
		"@opentelemetry/instrumentation-http": "^0.212.0",
		"@opentelemetry/resources": "^2.5.1",
		"@opentelemetry/sdk-trace-base": "^2.5.1",
		"@opentelemetry/sdk-trace-node": "^2.5.1",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@supabase/supabase-js": "^2.98.0",
		"@triathlon/core": "workspace:*",
		"@triathlon/types": "workspace:*",
		"ai": "^6.0.105",
		"hono": "4.12.7",
		"jose": "^6.1.3",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22.19.12",
		"esbuild": "^0.27.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
