# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Azure AI Foundry
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_INSTANCE_NAME=your-resource-name
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# Optional. Leave blank to disable semantic memory recall until an embeddings deployment exists in Azure.
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=
# Optional override. The API defaults to 2024-12-01-preview in code.
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Webhook Secrets
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
POLAR_WEBHOOK_SECRET=
WAHOO_CLIENT_ID=
WAHOO_CLIENT_SECRET=
WAHOO_WEBHOOK_TOKEN=

# Strava (https://www.strava.com/settings/api)
# Rate limits: 200 req/15min, 2000 daily; Read: 100 req/15min, 1000 daily
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=jpx-triathlon-strava

# Token encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Demo/prod should set INTEGRATION_ENCRYPTION_KEY. APP_SIGNING_SECRET is a
# local/dev fallback only and is not used for Supabase JWT verification.
INTEGRATION_ENCRYPTION_KEY=
APP_SIGNING_SECRET=

# App
APP_ENV=local
FEATURE_AI_ENABLED=true
FEATURE_INTEGRATIONS_ENABLED=true
FEATURE_MCP_ENABLED=true
# Comma-separated allowlist for OAuth callback return targets
ALLOWED_OAUTH_RETURN_ORIGINS=https://jpx.nu,http://localhost:3100
WEB_URL=http://localhost:3100
API_URL=http://localhost:8787
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_WEB_URL=http://localhost:3100
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true
NEXT_PUBLIC_ENABLE_DEMO=true
PORT=8787

# Playwright live browser tests
# Leave PLAYWRIGHT_TEST_EMAIL and PLAYWRIGHT_TEST_PASSWORD blank to use the live demo athlete locally.
PLAYWRIGHT_BASE_URL=http://localhost:3100/workout
PLAYWRIGHT_TEST_EMAIL=
PLAYWRIGHT_TEST_PASSWORD=
