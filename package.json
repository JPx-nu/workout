{
	"name": "triathlon-app",
	"version": "0.1.0",
	"private": true,
	"description": "Triathlon AI SaaS — Club-Agnostic AI Coaching Platform",
	"packageManager": "pnpm@10.29.2",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "biome check . && pnpm check:web-public-env-access",
		"check:web-public-env-access": "node scripts/check-web-public-env-access.mjs",
		"check:env-keys": "node scripts/check-env-keys.mjs",
		"test": "turbo test",
		"test:e2e": "turbo test:e2e",
		"type-check": "turbo type-check",
		"format": "biome format --write .",
		"clean": "turbo clean && rm -rf node_modules",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^22.19.12",
		"husky": "^9.1.7",
		"turbo": "^2.8.11"
	},
	"pnpm": {
		"overrides": {
			"express-rate-limit": ">=8.2.2"
		}
	}
}
